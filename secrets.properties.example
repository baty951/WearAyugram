# Скопируй в secrets.properties и заполни своими значениями.
# Telegram API (получить на https://my.telegram.org)
TG_API_ID=0
TG_API_HASH=your_api_hash_here
# Release signing (создать: keytool -genkeypair -keystore wearayugram-release.keystore ...)
RELEASE_STORE_FILE=../wearayugram-release.keystore
RELEASE_STORE_PASSWORD=changeme
RELEASE_KEY_ALIAS=wearayugram
RELEASE_KEY_PASSWORD=changeme
